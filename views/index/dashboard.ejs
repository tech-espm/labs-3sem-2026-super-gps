<link rel="stylesheet" href="<%- staticRoot %>/css/dashboard.css">

<div class="container-fluid py-4">

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-1 text-gray-800 display-dashboard"></h1>
            <h4 class="mb-0 text-muted">
                Monitoramento das viagens, ocupação, atrasos e desempenho das vans.
            </h4>
        </div>

        <button id="btnLimparFiltros" class="btn btn-outline-secondary btn-sm mt-3 mt-sm-0">
            <i class="fas fa-undo-alt mr-1"></i>
            Limpar filtros
        </button>
    </div>

    <!-- FILTROS -->
    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="form-row filtro-dashboard">

                <div class="form-group col-12 col-md-4">
                    <label for="filtroRota">Rota</label>
                    <select id="filtroRota" class="form-control">
                        <option value="">Todas as rotas</option>
                    </select>
                </div>

                <div class="form-group col-12 col-md-4">
                    <label for="filtroStatus">Status da viagem</label>
                    <select id="filtroStatus" class="form-control">
                        <option value="">Todos os status</option>
                    </select>
                </div>

                <div class="form-group col-12 col-md-4">
                    <label for="filtroVan">Van</label>
                    <select id="filtroVan" class="form-control">
                        <option value="">Todas as vans</option>
                    </select>
                </div>

            </div>

            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <small class="text-muted">
                    Os cartões, gráficos e a tabela são atualizados automaticamente.
                </small>

                <span id="totalFiltrado" class="badge badge-light border mt-2 mt-sm-0">
                    0 registros encontrados
                </span>
            </div>
        </div>
    </div>

    <!-- KPIs -->
    <div class="row">

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card dashboard-kpi kpi-primary border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Total de viagens
                            </div>
                            <div id="kpiViagens" class="h4 mb-0 font-weight-bold text-gray-800">0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-route fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card dashboard-kpi kpi-success border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Ocupação média
                            </div>
                            <div id="kpiOcupacao" class="h4 mb-0 font-weight-bold text-gray-800">0%</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card dashboard-kpi kpi-warning border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Atraso médio
                            </div>
                            <div id="kpiAtraso" class="h4 mb-0 font-weight-bold text-gray-800">0 min</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card dashboard-kpi kpi-danger border-left-danger shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">
                                Viagens críticas
                            </div>
                            <div id="kpiCriticas" class="h4 mb-0 font-weight-bold text-gray-800">0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- GRÁFICOS PRINCIPAIS -->
    <div class="row">

        <div class="col-xl-8 col-lg-7 mb-4">
            <div class="card shadow h-100">
                <div class="card-header card-header-dashboard">
                    <i class="fas fa-chart-bar mr-2 text-primary"></i>
                    Quantidade de viagens por rota
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="graficoRotas"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-5 mb-4">
            <div class="card shadow h-100">
                <div class="card-header card-header-dashboard">
                    <i class="fas fa-chart-pie mr-2 text-success"></i>
                    Distribuição por status
                </div>
                <div class="card-body">
                    <div class="chart-container chart-small">
                        <canvas id="graficoStatus"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row">

        <div class="col-xl-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header card-header-dashboard">
                    <i class="fas fa-user-friends mr-2 text-info"></i>
                    Ocupação média por van
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="graficoOcupacao"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-6 mb-4">
            <div class="card shadow h-100">
                <div class="card-header card-header-dashboard">
                    <i class="fas fa-chart-line mr-2 text-warning"></i>
                    Evolução diária do atraso médio
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="graficoAtraso"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- TABELA -->
    <div class="card shadow mb-4">
        <div class="card-header card-header-dashboard d-flex justify-content-between align-items-center">
            <span>
                <i class="fas fa-table mr-2 text-secondary"></i>
                Resumo operacional por rota
            </span>
            <small class="text-muted d-none d-md-inline">Clique nos gráficos para aplicar filtros</small>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover tabela-dashboard mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>Rota</th>
                            <th class="text-center">Viagens</th>
                            <th class="text-center">Estudantes</th>
                            <th class="text-center">Ocupação</th>
                            <th class="text-center">Tempo médio</th>
                            <th class="text-center">Atraso médio</th>
                            <th class="text-center">Status predominante</th>
                        </tr>
                    </thead>
                    <tbody id="corpoTabela"></tbody>
                </table>
            </div>
        </div>
    </div>

</div>

<%- contentFor("scripts") %>

<script src="https://cdn.jsdelivr.net/npm/chart.js@2.9.4/dist/Chart.min.js"></script>
<script src="<%- staticRoot %>/js/dashboard.js"></script>

<table class="table table-flush table-striped table-hover" id="tabela"></table>

<%- contentFor("scripts") %>
<script type="text/javascript">
	//<![CDATA[
	"use strict";

	var tabela = prepareDataTable("tabela", {
		order: [[1, "asc"]],
		deferRender: true,
		columns: [
			{ title: "", "class": "col-min", searchable: false, orderable: false, data: "id", render: function (v, type, row) { return '<a target="_blank" title="Editar" href="<%- root %>/van/editar?id=' + row.id + '" class="btn btn-sm btn-outline-primary"><i class="fa fa-fw fa-edit"></i></a> <button title="Excluir" type="button" data-excluir="1" class="btn btn-sm btn-outline-danger"><i class="fa fa-fw fa-times"></i></button>'; } },
			{ title: "Apelido", render: encode, data: "apelido" },
			{ title: "Placa", render: encode, data: "placa" },
			{ title: "Modelo", render: encode, data: "modelo" },
			{ title: "Capacidade", "class": "col-min text-right", data: "capacidade" },
			{ title: "Criação", "class": "col-min text-right", "type": "customdateint", data: "criacao" }
		],
		data: <%- JSON.stringify(lista) %>,
		export: { xlsx: true, title: "Vans" }
	});

	$("#tabela").on("click", "tbody button", function () {
		if (JsonWebApi.active)
			return;

		var trClicada = this.parentNode.parentNode,
			placa = null,
			van = tabela.row(trClicada).data();

		if (this.getAttribute("data-excluir")) {
			Swal.okcancel({
				html: 'Tem certeza que deseja excluir a van "' + van.apelido + '" (placa ' + van.placa + ')? Esta operação NÃO pode ser desfeita!<br/><br/>Para confirmar a exclusão, por favor, digite abaixo a placa da van conforme exibido acima.<br/><br/><label for="txtExcluirPlaca">Placa da van</label><input type="text" class="form-control" spellcheck="false" autocomplete="off" id="txtExcluirPlaca" />',
				confirmButtonText: "Excluir",
				preConfirm: function () {
					placa = $("#txtExcluirPlaca").val().toUpperCase();
					return true;
				}
			}, null, true).then(function (result) {
				if (JsonWebApi.active || !trClicada)
					return;

				if (result.value) {
					if (placa !== van.placa.toUpperCase()) {
						Swal.error("A placa da van não confere! " + emoji.sad);
						return;
					}

					Swal.wait();

					JsonWebApi.delete("<%- root %>/api/van/excluir", function (response) {
						if (response.success) {
							Swal.success("Van excluída com sucesso! " + emoji.happy);
							tabela.row(trClicada).remove().draw();
						} else {
							Swal.error(response.value + " " + emoji.sad);
						}
						trClicada = null;
					}, "id", van.id);
				}
			});
		}
	});

	//]]>
</script>
